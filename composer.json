{
    "name": "cypress-dashboard/app",
    "description": "Cypress Test Dashboard with branded reporting",
    "type": "project",
    "require": {
        "php": "^8.2",
        "dutchcodingcompany/filament-socialite": "2.4.0",
        "filament/filament": "3.3.49",
        "intervention/image": "3.11.7",
        "laravel/framework": "12.54.1",
        "laravel/reverb": "1.8.0",
        "laravel/sanctum": "4.3.1",
        "laravel/socialite": "5.25.0",
        "league/flysystem-aws-s3-v3": "3.32.0",
        "spatie/browsershot": "5.2.3",
        "spatie/laravel-permission": "6.24.1"
    },
    "require-dev": {
        "fakerphp/faker": "1.24.1",
        "laravel/pint": "1.29.0",
        "laravel/sail": "1.53.0",
        "phpunit/phpunit": "11.5.55"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ]
    },
    "config": {
        "platform": {
            "php": "8.4.0"
        },
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
