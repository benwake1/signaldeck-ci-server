APP_NAME="Cypress Dashboard"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_VERSION=dev                # Set automatically by deploy.sh from git tag

# Maximum seconds a Cypress job may run before being killed (default: 10800 = 3hrs)
# The queue worker --timeout must be >= this value (supervisor is set to 14400 = 4hrs)
CYPRESS_JOB_TIMEOUT=10800


# ---------------------------------------------------------------
# Branding (all optional — defaults used if not set)
# ---------------------------------------------------------------
BRAND_NAME=                    # Panel display name; defaults to APP_NAME
BRAND_PRIMARY_COLOR=           # Hex colour for the primary palette, e.g. #4f46e5
BRAND_LOGO_PATH=images/logo.svg        # Light-mode logo, path relative to public/
BRAND_LOGO_DARK_PATH=images/logo-white.svg # Dark-mode logo, path relative to public/
BRAND_LOGO_HEIGHT=2rem         # CSS height of the logo in the sidebar
BRAND_FAVICON_PATH=            # Path relative to public/, e.g. images/favicon.png
COMPANY_LEGAL_NAME="Important Business Named Ltd" # Company Legal Name for footer copyright notice

# ---------------------------------------------------------------
# Mail
# ---------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE=/absolute/path/to/database/database.sqlite

BROADCAST_CONNECTION=reverb

# Local development (no Redis needed)
CACHE_STORE=file
QUEUE_CONNECTION=database
DB_QUEUE_RETRY_AFTER=14400  # Must be >= CYPRESS_JOB_TIMEOUT to prevent jobs being re-queued mid-run

# Production — switch to redis and uncomment the block below
# CACHE_STORE=redis
# QUEUE_CONNECTION=redis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

SESSION_DRIVER=database
SESSION_LIFETIME=120

REVERB_APP_ID=my-app-id
REVERB_APP_KEY=my-app-key
REVERB_APP_SECRET=my-app-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Git settings
GIT_SSH_KEY_PATH=/home/www-data/.ssh

# Node paths — used by the web server for Playwright project discovery.
# The deploy script auto-detects these, but set manually if needed.
# Run `which node` and `which npm` to find the correct paths.
NODE_PATH=/usr/local/bin/node
NPM_PATH=/usr/local/bin/npm

# Report storage (local or s3)
FILESYSTEM_DISK=local

# Optional S3 config
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/admin/oauth/callback/google"
